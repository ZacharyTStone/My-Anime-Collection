{
  "name": "myanimecollection",
  "version": "1.0.1",
  "description": "A anime tracking application",
  "main": "Server/server.ts",
  "type": "module",
  "scripts": {
    "install-Client": "cd Client && npm install --include=dev",
    "install-Server": "npm install --include=dev",
    "build-Client": "cd Client && npm run build",
    "install-dependencies": "npm run install-Client && npm run install-Server",
    "heroku-postbuild": "npm run install-dependencies && npm run build-Client && tsc",
    "start-heroku-server": "node dist/server.js",
    "Server-local": "tsx watch Server/server.ts",
    "Client-local": "npm start --prefix Client",
    "start": "concurrently \"npm run Server-local\" \"npm run Client-local\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/validator": "^13.15.10",
    "sass": "^1.87.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcryptjs": "^3.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.1.0",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.1.4",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.0",
    "uuid": "^11.0.0",
    "validator": "^13.15.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
